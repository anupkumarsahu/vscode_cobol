 3415-20-SEARCH-PROCESS-TABLE-Y.
*    Continue searching serially to match the time window
     SEARCH PROCESS-TABLE
         END
*            When no link is found, we set PROCESS-INDEX
*            to zero
             SET PROCESS-INDEX TO ZERO
         WHEN PROCESS-CPU-NUM (PROCESS-INDEX) NOT =
                  OPENER-CPU OF ZMSDOPEN-DEFINITION
              OR  PROCESS-PIN (PROCESS-INDEX) NOT =
                  OPENER-PIN OF ZMSDOPEN-DEFINITION
*            When no link is found, we set PROCESS-INDEX
*            to zero
             SET PROCESS-INDEX TO ZERO
         WHEN
*            Process to discopen linking is done
*            according to the algorithm intoduced in the
*            MEASFH AAK IPM (MATCHEM_SUBPROC) First case:
*            process started first
         (     PROCESS-FROM (PROCESS-INDEX) <=
               FROM-TIMESTAMP OF ZMSDOPEN-DEFINITION
         AND
         (     PROCESS-TO (PROCESS-INDEX) >=
               TO-TIMESTAMP OF ZMSDOPEN-DEFINITION
         OR
         (     PROCESS-TO (PROCESS-INDEX) >
               FROM-TIMESTAMP OF ZMSDOPEN-DEFINITION
         AND
         (     (PROCESS-TO (PROCESS-INDEX) - PROCESS-FROM (PROCESS-INDEX))
               >=
               (TO-TIMESTAMP OF ZMSDOPEN-DEFINITION -
               FROM-TIMESTAMP OF ZMSDOPEN-DEFINITION)
         OR
               (PROCESS-TO (PROCESS-INDEX) -
               FROM-TIMESTAMP OF ZMSDOPEN-DEFINITION)
               > 10000000
         ))))
         OR
*              Second case: discopen started first
         (     PROCESS-FROM (PROCESS-INDEX) >
               FROM-TIMESTAMP OF ZMSDOPEN-DEFINITION
         AND
               PROCESS-FROM (PROCESS-INDEX) <
               TO-TIMESTAMP OF ZMSDOPEN-DEFINITION
         AND
         (     (PROCESS-TO (PROCESS-INDEX) - PROCESS-FROM (PROCESS-INDEX))
               >=
               (TO-TIMESTAMP OF ZMSDOPEN-DEFINITION -
               FROM-TIMESTAMP OF ZMSDOPEN-DEFINITION)
         OR
               (TO-TIMESTAMP OF ZMSDOPEN-DEFINITION -
               PROCESS-FROM (PROCESS-INDEX)) > 10000000
         ))
*              Bingo !!!
         CONTINUE
     END-SEARCH.
