*----------------------------------------------------------------------------
 3255-CALCULATE.
*------------MeasTCM Yosemite Change----Start-----------
* SEEK-BUSY-TIME counter is not present in ZMSDISC-Definition.
* Hence, the code below should NOT execute for YOSEMITE.
   IF YOSEMITE-DATAFILE = "N"
*------------MeasTCM Yosemite Change-----End------------
*      For each volume, increment read and write busy time to include
*      explicit seek busy time.
     IF VOLUME-SEEK-BUSY-TIME             (VOLUME-INDEX) NOT ZERO AND
        VOLUME-READ-BUSY-TIME             (VOLUME-INDEX) NOT ZERO AND
        VOLUME-WRITE-BUSY-TIME            (VOLUME-INDEX) NOT ZERO
* Soln 10-001226-8148. For correct computation of Volume-write-busy-time, store
* the denominator, (Volume-read-busy-time + Volume-write-busy-time), in a temp
* variable because Volume-read-busy-time is modified in the next computation.
         COMPUTE TEMP-DENOMINATOR = VOLUME-READ-BUSY-TIME  (VOLUME-INDEX) +
                           VOLUME-WRITE-BUSY-TIME (VOLUME-INDEX)
         COMPUTE VOLUME-READ-BUSY-TIME   (VOLUME-INDEX) =
                 VOLUME-READ-BUSY-TIME   (VOLUME-INDEX) +
                 VOLUME-READ-BUSY-TIME   (VOLUME-INDEX) *
                 VOLUME-SEEK-BUSY-TIME   (VOLUME-INDEX) /
                 TEMP-DENOMINATOR
* Commented for Soln 10-001226-8148.
*                 (VOLUME-READ-BUSY-TIME  (VOLUME-INDEX) +
*                  VOLUME-WRITE-BUSY-TIME (VOLUME-INDEX))
         COMPUTE VOLUME-WRITE-BUSY-TIME   (VOLUME-INDEX) =
                 VOLUME-WRITE-BUSY-TIME   (VOLUME-INDEX) +
                 VOLUME-WRITE-BUSY-TIME   (VOLUME-INDEX) *
                 VOLUME-SEEK-BUSY-TIME    (VOLUME-INDEX) /
                 TEMP-DENOMINATOR
* Commented for Soln 10-001226-8148.
*                 (VOLUME-READ-BUSY-TIME   (VOLUME-INDEX) +
*                  VOLUME-WRITE-BUSY-TIME  (VOLUME-INDEX))
     END-IF
*------------MeasTCM Yosemite Change----Start-----------
   END-IF.
*------------MeasTCM Yosemite Change-----End------------
*    For each volume, calculate the cost of a read and a write
*    (including seek).
     IF VOLUME-READS (VOLUME-INDEX) NOT ZERO
         DIVIDE VOLUME-READ-BUSY-TIME          (VOLUME-INDEX) BY
                VOLUME-READS                   (VOLUME-INDEX) GIVING
                DISC-READ-COST                 (VOLUME-INDEX)
     ELSE
         MOVE ZERO TO DISC-READ-COST           (VOLUME-INDEX)
     END-IF.
     IF VOLUME-WRITES (VOLUME-INDEX) NOT ZERO
         DIVIDE VOLUME-WRITE-BUSY-TIME         (VOLUME-INDEX) BY
                VOLUME-WRITES                  (VOLUME-INDEX) GIVING
                DISC-WRITE-COST                (VOLUME-INDEX)
     ELSE
         MOVE ZERO TO DISC-WRITE-COST          (VOLUME-INDEX)
     END-IF.
*    For each volume, calculate the disc-to-discopen ratio
*    (including seek).
     IF VOLUME-DOPN-READS (VOLUME-INDEX) NOT ZERO
         DIVIDE VOLUME-READS                   (VOLUME-INDEX) BY
                VOLUME-DOPN-READS              (VOLUME-INDEX) GIVING
                DISC-TO-DOPN-READ-RATIO        (VOLUME-INDEX)
           ON SIZE ERROR
               MOVE MAX-VALUE-13 TO DISC-TO-DOPN-READ-RATIO(VOLUME-INDEX)
     ELSE
         MOVE ZERO TO DISC-TO-DOPN-READ-RATIO  (VOLUME-INDEX)
     END-IF.
     IF VOLUME-DOPN-WRITES (VOLUME-INDEX) NOT ZERO
         DIVIDE VOLUME-WRITES                  (VOLUME-INDEX) BY
                VOLUME-DOPN-WRITES             (VOLUME-INDEX) GIVING
                DISC-TO-DOPN-WRITE-RATIO       (VOLUME-INDEX)
           ON SIZE ERROR
               MOVE MAX-VALUE-13 TO DISC-TO-DOPN-WRITE-RATIO(VOLUME-INDEX)
     ELSE
         MOVE ZERO TO DISC-TO-DOPN-WRITE-RATIO (VOLUME-INDEX)
     END-IF.
*    Display debug fields
     IF DEBUG-MODE
         DISPLAY                        SPACE,
             VOLUME-SYSTEM-NUMBER     (VOLUME-INDEX), SPACE,
             VOLUME-NAME              (VOLUME-INDEX), SPACE,
             VOLUME-DEV-SUBTYPE       (VOLUME-INDEX), SPACE,
             DISC-READ-COST           (VOLUME-INDEX), SPACE,
             DISC-WRITE-COST          (VOLUME-INDEX), SPACE,
             DISC-TO-DOPN-READ-RATIO  (VOLUME-INDEX), SPACE,
             DISC-TO-DOPN-WRITE-RATIO (VOLUME-INDEX)
     END-IF.
