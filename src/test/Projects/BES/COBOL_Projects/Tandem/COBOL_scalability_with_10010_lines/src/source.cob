 4010-PRINT-LOOP.
* Get next record from sort
     RETURN SORT-FILE
         AT END
             SET LAST-RECORD-RETURNED TO TRUE
             PERFORM 4050-PRINT-TOTAL
             PERFORM 4030-END-OF-PAGE
         NOT AT END
             PERFORM 4015-MAIN-PRINT
