*----------------------------------------------------------------------------
 3340-MATCH-WKLD.
* Match a process to a workload
     IF
*          Compare system numbers
         ((WKLD-SYSTEM (WKLD-INDEX) = WC-ASTERISK-NUM       OR
           WKLD-SYSTEM (WKLD-INDEX) = SYSTEM-INDEX                  )  AND
*          Compare CPU numbers
          (WKLD-CPU    (WKLD-INDEX) = WC-ASTERISK-NUM       OR
           WKLD-CPU    (WKLD-INDEX) = PROCESS-CPU-NUM (PROCESS-INDEX)) AND
*          Compare PIN numbers
          (WKLD-PIN    (WKLD-INDEX) = WC-ASTERISK-NUM       OR
           WKLD-PIN    (WKLD-INDEX) = PROCESS-PIN     (PROCESS-INDEX)) AND
*          Compare userid
          (WKLD-USERID-FLAG (WKLD-INDEX)  = WC-ASTERISK-ALFA OR
           (WKLD-USERID-FLAG (WKLD-INDEX) = USER-DEFINED  AND
            WKLD-USER        (WKLD-INDEX) = S-USER        )  OR
           (WKLD-USERID-FLAG (WKLD-INDEX) = GROUP-DEFINED AND
            WKLD-GROUP       (WKLD-INDEX) = S-GROUP       )  OR
           (WKLD-USERID-FLAG (WKLD-INDEX) = SPACE         AND
            WKLD-GROUP       (WKLD-INDEX) = S-GROUP       AND
            WKLD-USER        (WKLD-INDEX) = S-USER        )))
*          Match !
         PERFORM 3342-MATCH-WILD
     END-IF.
*----------------------------------------------------------------------------
 3342-MATCH-WILD.
* Generic rules for wildcard matching
* -----------------------------------
* The presence of a question mark (?) in any part (of the 3 parts) of a
* file name means that any character can occupy that position.
*
* For example, the pattern
*     "$ABC    FIL?REC DATA    "
* matches with the file names
*     "$ABC    FIL1REC DATA    "
*     "$ABC    FILKREC DATA    "
*
* Also, the pattern
*     "$ABC    FILE    DATA?   "
* matches with
*     "$ABC    FILE    DATA1   "
*     "$ABC    FILE    DATA    "
* but not with
*     "$ABC    FILE    DATA33  "
*
* The presence of an asterisk (*) in a any part (of the 3 parts) of a file
* name means that any character can occupy that position or any of the
* remaining positions in that part.
*
* For example, the pattern
*     "$ABC*   FILE    DATA    "
* matches with the file names
*     "$ABCD   FILE    DATA    "
*     "$ABC12  FILE    DATA    "
*     "$ABC    FILE    DATA    "
*
* Any characters that follow the asterisk wildcard up to the next part of the
* file name will be ignored.
*
* For example, the pattern "$ABC    FIL*REC DATA    " is identical to
* "$ABC    FIL*    DATA    ".
* Compare process name character by character
     PERFORM
         VARYING ORDINAL FROM 1 BY 1
         UNTIL ORDINAL > 8
         IF WKLD-PROCESS-NAME (WKLD-INDEX) (ORDINAL:1) = WC-ASTERISK-ALFA
             MOVE 8 TO ORDINAL
         ELSE
             IF WKLD-PROCESS-NAME (WKLD-INDEX) (ORDINAL:1) = WC-QUESTION
                 CONTINUE
             ELSE
                 IF WKLD-PROCESS-NAME (WKLD-INDEX) (ORDINAL:1) NOT =
                     S-PROCESS-NAME (ORDINAL:1)
* No match !
                     MOVE 999 TO ORDINAL
                 END-IF
             END-IF
         END-IF
     END-PERFORM.
     IF ORDINAL NOT > 999
*       Compare program file name, character by character
         PERFORM 3360-MATCH-PART
             VARYING OFFSET FROM ZERO BY 8
             UNTIL OFFSET > 16
         IF ORDINAL NOT > 999
*            All tests completed succesfully so a match is found
             SET MATCH-FOUND TO TRUE
         END-IF
     END-IF.
*----------------------------------------------------------------------------
 3360-MATCH-PART.
* Compare part of program file name
     PERFORM
         VARYING ORDINAL FROM 1 BY 1
         UNTIL ORDINAL > 8
         IF WKLD-PROGRAM-FILENAME (WKLD-INDEX) ((OFFSET + ORDINAL):1) =
             WC-ASTERISK-ALFA
             MOVE 8 TO ORDINAL
         ELSE
             IF WKLD-PROGRAM-FILENAME (WKLD-INDEX) ((OFFSET + ORDINAL):1) =
                 WC-QUESTION
                 CONTINUE
             ELSE
                 IF WKLD-PROGRAM-FILENAME (WKLD-INDEX) ((OFFSET + ORDINAL):1)
                     NOT = S-PROGRAM-FILE-NAME ((OFFSET + ORDINAL):1)
* No match !
                     MOVE 999 TO ORDINAL, OFFSET
                 END-IF
             END-IF
         END-IF
     END-PERFORM.
