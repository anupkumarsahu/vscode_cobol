* This module adds the cpu busy time of priority 255 processes to
* a temporary variable.
 9980-COMPUTE-INTR-AUX.
     IF CONVERTTO-PRESENT
        COMPUTE INTR-AUX-BUSY                             =
         INTR-AUX-BUSY                                    +
         CPU-BUSY-TIME OF ZMSPROC-DEFINITION *
         (CPU-POWER (CPU-INDEX)                            /
         CPU-POWER-VALUE)                    *
         (CONVERTTO-IPU-VALUE                              /
         CPU-IPUCOUNT (CPU-INDEX))
         ON SIZE ERROR
         MOVE MAX-VALUE-19 TO W05 OF CSV-W-BINARY (TITLE-INDEX)
     END-COMPUTE
     ELSE
     ADD CPU-BUSY-TIME OF ZMSPROC-DEFINITION TO INTR-AUX-BUSY
     END-IF.
