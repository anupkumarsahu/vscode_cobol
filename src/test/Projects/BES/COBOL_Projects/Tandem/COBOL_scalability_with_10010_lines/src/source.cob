 6005-CALC-DEVTYPE.
     ADD 1 TO TEMP-INDEX.
     MOVE "," TO V01-COMMA1 (TEMP-INDEX).
     IF TEMP-INDEX >= NO-DEV-TYPE-ENTRIES
       MOVE 0 TO V02-SUBTYPE (TEMP-INDEX)
     ELSE
       MOVE VOLUME-DEV-SUBTYPE (VOLUME-INDEX) TO V02-SUBTYPE (TEMP-INDEX)
     END-IF.
     MOVE "," TO V03-COMMA2 (TEMP-INDEX).
     MOVE ZERO TO V04-COUNT (TEMP-INDEX).
     PERFORM VARYING VOLUME-INDEX-2 FROM VOLUME-INDEX BY 1
               UNTIL VOLUME-INDEX-2 > VOLUME-MAX
       IF VOLUME-DEV-SUBTYPE (VOLUME-INDEX-2) > 0
         IF TEMP-INDEX >= NO-DEV-TYPE-ENTRIES
           ADD 1 TO V04-COUNT (TEMP-INDEX)
           MOVE ZERO TO VOLUME-DEV-TYPE (VOLUME-INDEX-2)
           MOVE ZERO TO VOLUME-DEV-SUBTYPE (VOLUME-INDEX-2)
         ELSE
           IF VOLUME-DEV-SUBTYPE (VOLUME-INDEX-2) = V02-SUBTYPE (TEMP-INDEX)
             ADD 1 TO V04-COUNT (TEMP-INDEX)
             MOVE ZERO TO VOLUME-DEV-TYPE (VOLUME-INDEX-2)
             MOVE ZERO TO VOLUME-DEV-SUBTYPE (VOLUME-INDEX-2)
           END-IF
         END-IF
       END-IF
     END-PERFORM.
     IF TEMP-INDEX >= NO-DEV-TYPE-ENTRIES
       MOVE ZERO TO TEMP-INDEX
     END-IF.
     SET VOLUME-INDEX TO 1.
