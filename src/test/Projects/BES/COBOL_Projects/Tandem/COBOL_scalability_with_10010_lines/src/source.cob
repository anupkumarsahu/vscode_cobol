*-----------Soln 10-060505-6280--start----
* Removed as all 255 processes are reported as interrupts
* This clause arbitrates the priority 255 processes to be allocated
* between the SYSTEM or OTHER category bucket.
*     IF SYS-FLAG = 1
*        IF  TITLE-NAME (TITLE-INDEX) = "SYSTEM"
*            PERFORM 9990-ADD-AUX-TO-CAT
*        END-IF
*     ELSE
*        IF  TITLE-NAME (TITLE-INDEX) = "OTHER"
*            PERFORM 9990-ADD-AUX-TO-CAT
*        END-IF
*     END-IF.
*-----------Soln 10-060505-6280--end----
     DIVIDE W05 OF CSV-W-BINARY (TITLE-INDEX) BY 1000000
         GIVING W05 OF CSV-W-DATA.
     DIVIDE W08 OF CSV-W-BINARY (TITLE-INDEX) BY 1000000
         GIVING W08 OF CSV-W-DATA.
     DIVIDE W09 OF CSV-W-BINARY (TITLE-INDEX) BY 1000000
         GIVING W09 OF CSV-W-DATA.
     IF W05 OF CSV-W-BINARY (TITLE-INDEX) ZERO
         MOVE ZERO TO W21 OF CSV-W-DATA
     ELSE
         DIVIDE W21 OF CSV-W-BINARY (TITLE-INDEX)
             BY W05 OF CSV-W-BINARY (TITLE-INDEX)
             GIVING W21 OF CSV-W-DATA
     END-IF.
     IF RISC-DATA-PRESENT
*        TNSR-BUSY-TIME secs
         DIVIDE W22 OF CSV-W-BINARY (TITLE-INDEX) BY 1000000
             GIVING W22 OF CSV-W-DATA
*        ACCEL-BUSY-TIME secs
         DIVIDE W23 OF CSV-W-BINARY (TITLE-INDEX) BY 1000000
             GIVING W23 OF CSV-W-DATA
     ELSE
*        Indicate NULL fields for no RISC data
         MOVE SPACES TO W22-NULL
         MOVE SPACES TO W23-NULL
     END-IF.
