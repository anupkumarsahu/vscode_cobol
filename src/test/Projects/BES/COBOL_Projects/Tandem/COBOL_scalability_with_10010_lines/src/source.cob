*----------------------------------------------------------------------------
 IDENTIFICATION DIVISION.
 PROGRAM-ID. SPCOMPLETION COMMON.
 AUTHOR. Sangeetha
 INSTALLATION. HP NonStop Systems.
* Moving 9000-COMPLETION and the related modules here
*      9000-COMPLETION.                    Shutdown processing.
*----------------------------------------------------------------------------
 PROCEDURE DIVISION.
*----------------------------------------------------------------------------
 9000-COMPLETION.
* Close control file
     IF NOT CONTROL-FILE-CLOSED
         CLOSE CONTROL-FILE
     END-IF.
* Close measurement data files
     PERFORM
         VARYING MEASURE-INDEX FROM 1 BY 1
         UNTIL MEASURE-INDEX > MEASURE-MAX
         IF MEASURE-DFNUM (MEASURE-INDEX) NOT ZERO
             ENTER TAL "MEASCLOSE"
                 USING MEASURE-DFNUM (MEASURE-INDEX)
                 GIVING RESULT
         END-IF
     END-PERFORM.
** Output run summary.
* Soln 10-000602-8415. Print COMPLETION-89/90 message and do not print the
* run summary if COMPLETION-89 or 90 is encountered.
   IF COMPLETION-MESSAGE (1:2) NOT = "89" AND "90"
     IF C-WRITE-RUN-SUMMARY
*        PERFORM 7000-DISPLAY-SUMMARY
     END-IF
     IF C-SPOOL-FILE-OPEN
        PERFORM 8000-WRITE-SUMMARY
     END-IF
* Soln 10-040510-5889 : start
     IF DISKCONVERTTO-PRESENT
      DISPLAY "WARNING: The Disk Count has not been scaled, only the Disk Busy Seconds"
      DISPLAY "have been scaled according to the DISKCONVERTTO Type."
      DISPLAY "  "
     END-IF
* Soln 10-040510-5889 : end
     PERFORM 8500-CHECK-OVERFLOW-VALUES
   END-IF.
     MOVE TERMINATION-INFO-D TO TERMINATION-INFO
     IF NOT ABEND-REQUIRED
*        Normal termination
         MOVE ZERO TO ABEND-OR-STOP, COMPLETION-CODE
     ELSE
*        Error termination
         MOVE 3 TO ABEND-OR-STOP, COMPLETION-CODE
     END-IF.
*------------MeasTCM Yosemite Change----Start-----------
     IF YOSEMITE-DATAFILE = "Y"
        MOVE CURRENTVERSION-YOSEMITE TO Z-VERSION OF STCM-VAL-SSID
     ELSE
        MOVE CURRENTVERSION TO Z-VERSION OF STCM-VAL-SSID
     END-IF.
*------------MeasTCM Yosemite Change-----End------------
     ENTER "COBOL85^COMPLETION" OF CBL85UTL
         USING     ABEND-OR-STOP,
                   COMPLETION-CODE,
                   TERMINATION-INFO,
                   STCM-VAL-SSID,
                   80,
                   TERMINATION-TEXT.
    EXIT PROGRAM.
*----------------------------------------------------------------------------
 7000-DISPLAY-SUMMARY.
      DISPLAY SPACE.
      DISPLAY RUN-SUM-HEADING.
      DISPLAY SPACE.
      DISPLAY RUN-SUM-HEADING-2.
      DISPLAY SPACE.
      PERFORM
         VARYING TEMP-INDEX FROM 1 BY 1
         UNTIL   RUN-MEAS-LINE-1(TEMP-INDEX) = SPACES OR
                 TEMP-INDEX > MEASURE-MAX
          DISPLAY RUN-MEAS-LINE-1(TEMP-INDEX)
          DISPLAY RUN-MEAS-LINE-2(TEMP-INDEX)
          PERFORM
             VARYING RUN-MEAS-MSG-INDX FROM 1 BY 1
             UNTIL RUN-MEAS-MSG-INDX > 7
             IF RUN-MEAS-ADV(TEMP-INDEX, RUN-MEAS-MSG-INDX) NOT = SPACE
                DISPLAY RUN-MEAS-ADV(TEMP-INDEX, RUN-MEAS-MSG-INDX)
             END-IF
          END-PERFORM
          DISPLAY SPACE
      END-PERFORM.
      DISPLAY RUN-MEAS-FILE-ADV.
      DISPLAY SPACE
      IF NOT C-EXIT-PROGRAM
         PERFORM 7010-SUMMARY-PART-2
      END-IF.
*----------------------------------------------------------------------------
 7010-SUMMARY-PART-2.
      DISPLAY RUN-SUM-CSV-HEAD.
      DISPLAY SPACE.
      DISPLAY RUN-SUM-CSV-LINE-1.
      DISPLAY RUN-SUM-CSV-LINE-2.
      DISPLAY RUN-SUM-CSV-LINE.
      DISPLAY SPACE.
      IF NOT C-EXIT-PROGRAM
         PERFORM 7020-SUMMARY-PART-3
      END-IF.
*----------------------------------------------------------------------------
 7020-SUMMARY-PART-3.
      DISPLAY RUN-SUM-OUTPUT-HEAD.
      DISPLAY RUN-SUM-OUTPUT-LINE-1.
      DISPLAY RUN-SUM-OUTPUT-LINE-2.
      DISPLAY RUN-SUM-OUTPUT-LINE-3.
      DISPLAY SPACE.
      PERFORM
        VARYING TEMP-INDEX FROM 1 BY 1
        UNTIL RUN-CSV-LINE-1(TEMP-INDEX) = SPACES
             OR TEMP-INDEX > NUM-CSVS-ACTUAL
          DISPLAY RUN-CSV-LINE-1(TEMP-INDEX)
          DISPLAY RUN-CSV-LINE-2(TEMP-INDEX)
          IF RUN-CSV-ADV(TEMP-INDEX) NOT = SPACES
             DISPLAY RUN-CSV-ADV(TEMP-INDEX)
          END-IF
          DISPLAY SPACE
      END-PERFORM.
*----------------------------------------------------------------------------
 8000-WRITE-SUMMARY.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-HEADING AFTER ADVANCING PAGE.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-HEADING-2
         AFTER ADVANCING 2 LINES.
      MOVE ALL "-" TO RUN-UND-1
                      RUN-UND-2.
      WRITE SPOOLER-FILE-RECORD FROM RUN-UND-1.
      MOVE 4 TO LINE-CNT.
      PERFORM 8005-MEAS-SUMMARY
          VARYING TEMP-INDEX FROM 1 BY 1
          UNTIL RUN-MEAS-LINE-1(TEMP-INDEX) = SPACES
             OR TEMP-INDEX > MEASURE-MAX.
      IF LINE-CNT > 56
         WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-HEADING
                      AFTER ADVANCING PAGE
          MOVE 1 TO LINE-CNT
      END-IF
      WRITE SPOOLER-FILE-RECORD FROM RUN-MEAS-FILE-ADV
         AFTER ADVANCING 2 LINES.
      WRITE SPOOLER-FILE-RECORD from RUN-SUM-HEADING-2
      IF C-EXIT-PROGRAM
         CLOSE SPOOLER-FILE
      ELSE
         PERFORM 8010-SUMMARY-PART-2
      END-IF.
*----------------------------------------------------------------------------
 8005-MEAS-SUMMARY.
      IF LINE-CNT > 47
         WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-HEADING
                  AFTER ADVANCING PAGE
         MOVE 1 TO LINE-CNT
      END-IF.
      WRITE SPOOLER-FILE-RECORD FROM RUN-MEAS-LINE-1(TEMP-INDEX)
         AFTER ADVANCING 2 LINES.
      ADD 2 TO LINE-CNT.
      WRITE SPOOLER-FILE-RECORD FROM RUN-MEAS-LINE-2(TEMP-INDEX).
      ADD 1 TO LINE-CNT.
      PERFORM
         VARYING RUN-MEAS-MSG-INDX FROM 1 BY 1
         UNTIL RUN-MEAS-MSG-INDX > 7
        IF RUN-MEAS-ADV(TEMP-INDEX, RUN-MEAS-MSG-INDX) NOT = SPACE
           WRITE SPOOLER-FILE-RECORD
              FROM RUN-MEAS-ADV(TEMP-INDEX, RUN-MEAS-MSG-INDX)
           ADD 1 TO LINE-CNT
        END-IF
      END-PERFORM.
*----------------------------------------------------------------------------
 8010-SUMMARY-PART-2.
      ADD 2 TO LINE-CNT.
      IF LINE-CNT > 50
          WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-HEADING
                      AFTER ADVANCING PAGE
          MOVE 1 TO LINE-CNT
      END-IF.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-CSV-HEAD AFTER ADVANCING 2 LINES.
      ADD 2 TO LINE-CNT.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-CSV-LINE-1.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-CSV-LINE-2.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-CSV-LINE.
      IF C-EXIT-PROGRAM
         CLOSE SPOOLER-FILE
      ELSE
         PERFORM 8020-SUMMARY-PART-3
      END-IF.
*----------------------------------------------------------------------------
 8020-SUMMARY-PART-3.
      ADD 3 TO LINE-CNT.
      IF LINE-CNT > 51
          WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-HEADING
                      AFTER ADVANCING PAGE
          MOVE 1 TO LINE-CNT
      END-IF.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-OUTPUT-HEAD
          AFTER ADVANCING 2 LINES.
      WRITE SPOOLER-FILE-RECORD FROM RUN-UND-2.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-OUTPUT-LINE-1
          AFTER ADVANCING 2 LINES.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-OUTPUT-LINE-2.
      WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-OUTPUT-LINE-3.
      ADD 7 TO LINE-CNT.
      PERFORM 8030-CSV-SUMMARY
          VARYING TEMP-INDEX FROM 1 BY 1
          UNTIL RUN-CSV-LINE-1(TEMP-INDEX) = SPACES
              OR TEMP-INDEX > NUM-CSVS-ACTUAL.
      MOVE SPACES TO SPOOLER-FILE-RECORD.
      WRITE SPOOLER-FILE-RECORD.
      PERFORM 8050-SPOOL-OVERFLOW-VALUES.
      CLOSE SPOOLER-FILE.
*----------------------------------------------------------------------------
 8030-CSV-SUMMARY.
      IF LINE-CNT > 53
         WRITE SPOOLER-FILE-RECORD FROM RUN-SUM-HEADING
                  AFTER ADVANCING PAGE
         MOVE 1 TO LINE-CNT
      END-IF.
      WRITE SPOOLER-FILE-RECORD FROM RUN-CSV-LINE-1(TEMP-INDEX)
           AFTER ADVANCING 2 LINES.
      ADD 2 TO LINE-CNT.
      WRITE SPOOLER-FILE-RECORD FROM RUN-CSV-LINE-2(TEMP-INDEX).
      ADD 1 TO LINE-CNT.
      IF RUN-CSV-ADV(TEMP-INDEX) NOT = SPACE
         WRITE SPOOLER-FILE-RECORD FROM RUN-CSV-ADV(TEMP-INDEX)
         ADD 1 TO LINE-CNT
      END-IF.
*----------------------------------------------------------------------------
 8050-SPOOL-OVERFLOW-VALUES.
*   NOTE:  No need to check CPU as this can not happen at this time.
    IF OVERFLOW-OCCURED
       MOVE "TERMINATION WARNING:" TO SPOOLER-FILE-RECORD
       WRITE SPOOLER-FILE-RECORD AFTER ADVANCING PAGE
       MOVE "--------------------" TO SPOOLER-FILE-RECORD
       WRITE SPOOLER-FILE-RECORD
    END-IF.
	
    IF PROCESS-OVERFLOW-COUNT > 0
       MOVE PROCESS-OVERFLOW-COUNT TO NUMBER-DISPLAY
       STRING COMPLETION-55  DELIMITED BY SIZE
              NUMBER-DISPLAY DELIMITED BY SIZE
              " TIMES."      DELIMITED BY SIZE
       INTO COMPLETION-MESSAGE
       WRITE SPOOLER-FILE-RECORD FROM TERMINATION-TEXT
    END-IF.
	
    IF DISC-OVERFLOW-COUNT > 0
       MOVE DISC-OVERFLOW-COUNT TO NUMBER-DISPLAY
       STRING COMPLETION-53  DELIMITED BY SIZE
              NUMBER-DISPLAY DELIMITED BY SIZE
              " TIMES."      DELIMITED BY SIZE
       INTO COMPLETION-MESSAGE
       WRITE SPOOLER-FILE-RECORD FROM TERMINATION-TEXT
    END-IF.
	
    IF DISCOPEN-OVERFLOW-COUNT > 0
       MOVE DISCOPEN-OVERFLOW-COUNT TO NUMBER-DISPLAY
       STRING COMPLETION-63  DELIMITED BY SIZE
              NUMBER-DISPLAY DELIMITED BY SIZE
              " TIMES."      DELIMITED BY SIZE
       INTO COMPLETION-MESSAGE
       WRITE SPOOLER-FILE-RECORD FROM TERMINATION-TEXT
    END-IF.
*----------------------------------------------------------------------------


 
 
 
 
 
 
 
 
 8500-CHECK-OVERFLOW-VALUES.
*   NOTE:  No need to check CPU as this can not happen at this time.
    IF OVERFLOW-OCCURED
       DISPLAY SPACE
       DISPLAY "TERMINATION WARNING:"
       DISPLAY "--------------------"
    END-IF.
	
    IF PROCESS-OVERFLOW-COUNT > 0
       MOVE PROCESS-OVERFLOW-COUNT TO NUMBER-DISPLAY
       STRING COMPLETION-55  DELIMITED BY SIZE
              NUMBER-DISPLAY DELIMITED BY SIZE
              " TIMES."      DELIMITED BY SIZE
       INTO COMPLETION-MESSAGE
       DISPLAY TERMINATION-TEXT
    END-IF.
	
    IF DISC-OVERFLOW-COUNT > 0
       MOVE DISC-OVERFLOW-COUNT TO NUMBER-DISPLAY
       STRING COMPLETION-53  DELIMITED BY SIZE
              NUMBER-DISPLAY DELIMITED BY SIZE
              " TIMES."      DELIMITED BY SIZE
       INTO COMPLETION-MESSAGE
       DISPLAY TERMINATION-TEXT
    END-IF.
	
    IF DISCOPEN-OVERFLOW-COUNT > 0
       MOVE DISCOPEN-OVERFLOW-COUNT TO NUMBER-DISPLAY
       STRING COMPLETION-63  DELIMITED BY SIZE
              NUMBER-DISPLAY DELIMITED BY SIZE
              " TIMES."      DELIMITED BY SIZE
       INTO COMPLETION-MESSAGE
       DISPLAY TERMINATION-TEXT
    END-IF.
	
    IF OVERFLOW-OCCURED
       MOVE COMPLETION-87 TO COMPLETION-MESSAGE
       DISPLAY SPACE
    END-IF.
 END PROGRAM SPCOMPLETION.
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
