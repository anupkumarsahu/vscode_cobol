 4040-PRINT-TITLES.
* Print title information at top of new page
     IF ADVANCING-LINES ZERO
*        Skip the initial page feed
         WRITE SPOOLER-FILE-RECORD FROM P-TITLE-1
     ELSE
         WRITE SPOOLER-FILE-RECORD FROM P-TITLE-1 AFTER PAGE
     END-IF.
     WRITE SPOOLER-FILE-RECORD FROM P-TITLE-2.
     WRITE SPOOLER-FILE-RECORD FROM P-TITLE-21.
     WRITE SPOOLER-FILE-RECORD FROM P-TITLE-3 AFTER 2.
     WRITE SPOOLER-FILE-RECORD FROM P-TITLE-4 AFTER ZERO.
     MOVE 2 TO ADVANCING-LINES.
     SET FORCE-FULL-LINE TO TRUE.
