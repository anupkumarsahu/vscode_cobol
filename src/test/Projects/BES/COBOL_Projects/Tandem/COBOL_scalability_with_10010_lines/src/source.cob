                                      ACTUAL-READ-SEEK-VALUE
        END-COMPUTE
        COMPUTE DISK-WRITESEEK-RATIO = DISKTO-WRITE-SEEK-VALUE /
                                       ACTUAL-WRITE-SEEK-VALUE
        END-COMPUTE
        COMPUTE DISK-READPOWER-VALUE = DISK-RPM-RATIO * DISK-CNT-POWER-RATIO * DISK-READSEEK-RATIO
        END-COMPUTE
        COMPUTE DISK-WRITEPOWER-VALUE = DISK-RPM-RATIO * DISK-CNT-POWER-RATIO * DISK-WRITESEEK-RATIO
        END-COMPUTE
 END-IF.
 END PROGRAM SPDISKINFO.
